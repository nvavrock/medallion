{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://medallion.local/schemas/evidence_record.schema.json",
  "title": "EvidenceRecord",
  "type": "object",
  "required": [
    "claim_id",
    "text",
    "evidence_level",
    "source_quality",
    "sources",
    "replication_status",
    "counterarguments",
    "confidence",
    "last_verified"
  ],
  "properties": {
    "claim_id": {
      "type": "string",
      "pattern": "^CLM-[0-9]{4}-[0-9]{3,}$"
    },
    "text": { "type": "string", "minLength": 1 },
    "evidence_level": {
      "type": "string",
      "enum": ["E0", "E1", "E2", "E3", "E4"]
    },
    "source_quality": {
      "type": "string",
      "enum": ["S0", "S1", "S2", "S3"]
    },
    "sources": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 0
    },
    "replication_status": {
      "type": "string",
      "enum": ["not_attempted", "failed", "partial", "replicated"]
    },
    "counterarguments": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "last_verified": { "type": "string", "format": "date" },
    "status": {
      "type": "string",
      "enum": ["active", "retired"],
      "default": "active"
    }
  },
  "additionalProperties": false
}
