{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://medallion.local/schemas/signal_hypothesis.schema.json",
  "title": "SignalHypothesis",
  "type": "object",
  "required": [
    "signal_id",
    "signal",
    "theory",
    "evidence",
    "replication",
    "capacity",
    "confidence",
    "era_plausibility",
    "tags"
  ],
  "properties": {
    "signal_id": { "type": "string", "pattern": "^SIG-[0-9]{3}$" },
    "signal": { "type": "string" },
    "theory": { "type": "string" },
    "evidence": { "type": "string" },
    "evidence_level": { "type": "string", "enum": ["E0", "E1", "E2", "E3", "E4"] },
    "replication": { "type": "string" },
    "capacity": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "era_plausibility": { "type": "string" },
    "failure_modes": { "type": "string" },
    "alpha_half_life": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string", "enum": ["active", "retired"] }
  },
  "additionalProperties": false
}
